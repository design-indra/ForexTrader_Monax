# ════════════════════════════════════════════
#   ForexTrader — Environment Variables
#   Broker: PT Monex Investindo Futures (MONEX)
#   Regulasi: BAPPEBTI No. 442/BAPPEBTI/SI/VII/2007
# ════════════════════════════════════════════

# Monex API Credentials (untuk Live Mode)
# Daftar akun demo gratis di: https://www.mifx.com/id/akun-demo
# Untuk live API access: hubungi support@mifx.com
MONEX_API_KEY=your_monex_api_key_here
MONEX_ACCOUNT_ID=your_account_id_here
# Environment: demo | live
MONEX_ENV=demo

# Auth Login
AUTH_EMAIL=admin@forextrader.app
AUTH_PASSWORD=forextrader123

# Demo Mode Balance Awal (USD)
DEMO_BALANCE=10000

# Bot Risk Settings
MAX_POSITIONS=1
MAX_RISK_PERCENT=2
STOP_LOSS_PIPS=30
TAKE_PROFIT_PIPS=60
TRAILING_STOP_PIPS=15
MAX_CONSECUTIVE_LOSSES=3

# Lot Size (micro=0.01, mini=0.1, standard=1.0)
DEFAULT_LOT_SIZE=0.01

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
